yamlname: Automated Tensor T Matrix Scan

on: [push]

jobs:
  run-experiment:
    runs-on: ubuntu-latest
    steps:
      - name: Pobranie kodu z repozytorium
        uses: actions/checkout@v4

      - name: Konfiguracja środowiska Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Uruchomienie Sondy Siewnej (Zasysanie Uwagi)
        run: python probe_seeder.py

      - name: Uruchomienie Sondy Zbierającej (Retencja Danych)
        run: python probe_collector.py

      - name: Uruchomienie Silnika Analitycznego (Weryfikacja dP)
        run: python matrix_analyser.py

      - name: Archiwizacja i siew urobku danych (Upload Artifacts)
        uses: actions/upload-artifact@v4
        with:
          name: ainumpsa-matrix-results
          path: |
            collected_matrix_data.json
            ainumpsa_analysis_report.json
          retention-days: 7
